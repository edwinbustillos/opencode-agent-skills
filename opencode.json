{
  "$schema": "https://opencode.ai/config.json",
  "lsp": true,
  "permission": {
    "*": "allow",
    "bash": {
      "*": "ask",
      "git status*": "allow",
      "git diff*": "allow",
      "git log*": "allow",
      "ls*": "allow",
      "pwd": "allow",
      "which*": "allow",
      "node *": "allow",
      "npm *": "allow",
      "npx *": "allow",
      "bun *": "allow",
      "python *": "allow",
      "pip *": "allow",
      "dart *": "allow",
      "flutter *": "allow",
      "go *": "allow",
      "cargo *": "allow",
      "rustc *": "allow",
      "javac *": "allow",
      "java *": "allow",
      "mvn *": "allow",
      "gradle *": "allow",
      "gcc *": "allow",
      "g++ *": "allow",
      "cmake *": "allow",
      "make *": "allow",
      "docker *": "allow",
      "kubectl *": "allow",
      "aws *": "allow",
      "az *": "allow",
      "gh *": "allow",
      "rg *": "allow",
      "grep *": "allow",
      "find *": "allow",
      "curl *": "allow",
      "wget *": "allow",
      "cat *": "allow",
      "tree *": "allow",
      "rm *": "deny",
      "sudo *": "deny",
      "chmod 777*": "deny",
      "git push*": "ask",
      "git commit*": "ask",
      "git add .": "ask"
    },
    "edit": "allow",
    "webfetch": "allow",
    "websearch": "allow",
    "skill": "allow",
    "external_directory": {
      "~/projects/**": "allow",
      "~/work/**": "allow"
    }
  },
  "mcp": {
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp"
    },
    "gh_grep": {
      "type": "remote",
      "url": "https://mcp.grep.app"
    }
  },
  "agent": {
    "build": {
      "mode": "primary",
      "description": "Agente principal de desenvolvimento com todas as ferramentas habilitadas",
      "tools": {
        "write": true,
        "edit": true,
        "bash": true,
        "read": true,
        "grep": true,
        "glob": true,
        "skill": true,
        "todowrite": true,
        "webfetch": true,
        "websearch": true,
        "lsp": true
      }
    },
    "plan": {
      "mode": "primary",
      "description": "Agente de planejamento e análise sem fazer alterações no código",
      "temperature": 0.1,
      "tools": {
        "write": false,
        "edit": false,
        "bash": false,
        "read": true,
        "grep": true,
        "glob": true,
        "skill": true,
        "webfetch": true,
        "websearch": true,
        "lsp": true
      }
    },
    "tech-lead": {
